{
  "name": "character-factory",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @character-factory/web dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/db/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit",
    "test": "pnpm --filter @character-factory/core test && pnpm --filter @character-factory/db test && pnpm --filter @character-factory/web test",
    "db:migrate": "pnpm --filter @character-factory/db migrate",
    "db:seed": "pnpm --filter @character-factory/db seed"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "prettier": "3.8.2",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  }
}
