#!/usr/bin/env sh
set -eu

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

echo "[character_factory] Running CI verify pipeline before commit..."

if command -v pnpm >/dev/null 2>&1; then
  pnpm ci:verify
  exit 0
fi

if command -v corepack >/dev/null 2>&1; then
  corepack pnpm ci:verify
  exit 0
fi

echo "[character_factory] pnpm (or corepack) is required to commit."
echo "[character_factory] Install Node.js 22 and pnpm 10.33.0, then rerun the commit."
exit 1
